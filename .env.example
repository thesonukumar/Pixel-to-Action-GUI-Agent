# ============================================================
# Pixel-to-Action GUI Agent — Environment Variables
# ============================================================
# Copy this file to .env and fill in your API key.
# SECURITY: Never commit .env to version control.
# ============================================================

# --- Gemini Cloud Brain ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL_NAME=gemini-3.1-flash-lite
GEMINI_TEMPERATURE=0.1
GEMINI_MAX_OUTPUT_TOKENS=256

# --- Agent Execution Guardrails ---
MAX_STEPS=20
DELTA_THRESHOLD=3
MAX_RETRIES=3

# --- Display / DPR ---
# Set this to your monitor's Device Pixel Ratio.
# Windows standard: 1.0 | HiDPI/4K: 1.5 or 2.0 | Retina Mac: 2.0
DISPLAY_DPR=1.0

# --- OmniParser Local Model ---
OMNIPARSER_MODEL_PATH=./models/omniparser_v2.pt
OMNIPARSER_MODEL_INPUT_SIZE=640

# --- Logging ---
LOG_LEVEL=DEBUG
LOG_TO_FILE=true
LOG_DIR=./logs
